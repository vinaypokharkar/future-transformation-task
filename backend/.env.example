# Copy to .env and adjust. Never commit .env.

# --- Database ---
DATABASE_URL=mysql+pymysql://km_user:km_pass@localhost:3306/knowledge_mgmt
TEST_DATABASE_URL=mysql+pymysql://km_user:km_pass@localhost:3307/knowledge_mgmt_test

# --- Auth ---
# REQUIRED. The app will refuse to start until you replace this line: the value
# below is a known placeholder, and a token signed with it could be forged by
# anyone who has read this repository.
#
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
JWT_SECRET_KEY=change-me-in-production-use-a-real-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Must be the exact Vite origin. "*" plus credentials is rejected by browsers.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# --- AI / semantic search ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
CHUNK_SIZE=400
CHUNK_OVERLAP=50
FAISS_INDEX_PATH=data/faiss.index
SEARCH_TOP_K=5
# Calibrated empirically by scripts/calibrate.py â€” do not guess this value.
# See PLAN.md Step 3c. Overwritten once calibration has been run.
SIMILARITY_FLOOR=0.2668

# --- Seed accounts (development only) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_USER_PASSWORD=User@123
